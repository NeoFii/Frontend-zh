# Frontend API base prefix
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Company name
NEXT_PUBLIC_COMPANY_NAME=Eucal AI
NEXT_PUBLIC_IMAGE_HOSTS=eucal.ai,www.eucal.ai,neofii.fun

NEXT_PUBLIC_ROUTER_API_BASE_URL=/router-api/api/v1
NEXT_PUBLIC_ROUTER_OPENAI_BASE_URL=/router-api/v1

# Next.js rewrite targets
# 三节点架构：替换为实际内网 IP
API_URL=http://<BACKEND_IP>:8000
ROUTER_API_URL=http://<GPU_IP>:8003

# Enable standalone output for Docker builds if needed
# NEXT_STANDALONE=true
