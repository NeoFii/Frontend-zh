# Frontend API base prefix
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8001

# Company name
NEXT_PUBLIC_COMPANY_NAME=Eucal AI
NEXT_PUBLIC_IMAGE_HOSTS=eucal.ai,www.eucal.ai,neofii.fun

# Testing service URL
NEXT_PUBLIC_TESTING_API_URL=http://localhost:8002
NEXT_PUBLIC_TESTING_API_BASE_URL=http://localhost:8002/api
NEXT_PUBLIC_ROUTER_API_BASE_URL=http://localhost:8003/api/v1
NEXT_PUBLIC_ROUTER_OPENAI_BASE_URL=http://localhost:8003/v1

# Next.js rewrite targets
API_URL=http://127.0.0.1:8001
ROUTER_API_URL=http://127.0.0.1:8003

# Enable standalone output for Docker builds if needed
# NEXT_STANDALONE=true
