# ============================================================
# Eucal AI 中文前端 — Docker 部署配置
# ============================================================
# 使用方式: cp .env.example .env 然后修改下方配置

# ------------------------------------------------------------
# 构建时变量 (NEXT_PUBLIC_*)
# 会在 docker build 时烘焙到客户端 JS 中
# 修改后需要重新构建镜像: docker compose up -d --build
# ------------------------------------------------------------

# 浏览器端 API 基础路径（通常不需要修改，使用同源代理）
NEXT_PUBLIC_API_BASE_URL=/api/v1

# 公司名称（显示在页面标题和页脚）
NEXT_PUBLIC_COMPANY_NAME=Eucal AI

# 允许加载远程图片的域名（逗号分隔）
NEXT_PUBLIC_IMAGE_HOSTS=eucal.ai,www.eucal.ai,neofii.fun

# Router API 浏览器端基础路径
NEXT_PUBLIC_ROUTER_API_BASE_URL=/router-api/api/v1
NEXT_PUBLIC_ROUTER_OPENAI_BASE_URL=/router-api/v1

# 模型目录 API 基础路径（留空则使用 NEXT_PUBLIC_API_BASE_URL）
NEXT_PUBLIC_MODEL_CATALOG_API_BASE_URL=

# ------------------------------------------------------------
# 运行时变量
# 容器启动时生效，修改后重启容器即可（无需重新构建）
# ------------------------------------------------------------

# Next.js 服务端代理目标 — 主后端 API
# Docker 网络中使用服务名，如 http://eucal_backend:8000
API_URL=http://eucal_backend:8000

# Next.js 服务端代理目标 — Router API
# Docker 网络中使用服务名，如 http://eucal_router:8003
ROUTER_API_URL=http://eucal_router:8003

# ------------------------------------------------------------
# 部署配置
# ------------------------------------------------------------

# 前端对外暴露端口
FRONTEND_PORT=3000

# Node.js 环境
NODE_ENV=production

# 禁用 Next.js 遥测
NEXT_TELEMETRY_DISABLED=1

# ------------------------------------------------------------
# 镜像分发（可选）
# ------------------------------------------------------------

# Docker Registry 地址（用于 ./deploy.sh push）
# 示例: registry.example.com/eucal
REGISTRY_URL=
